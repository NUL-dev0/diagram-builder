{
  "name": "diagram-builder",
  "version": "1.0.0",
  "private": true,
  "main": ".electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:custom": "eslint \"app/**/*.{ts,tsx}\" --ignore-pattern \"node_modules/\"",
    "lint:custom:fix": "eslint \"app/**/*.{ts,tsx}\" --fix --ignore-pattern \"node_modules/\"",
    "electron:compile": "tsc --project tsconfig.electron.json",
    "electron:dev": "npm run electron:compile && electron .",
    "electron:build": "next build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && cd backend && npm run build && cd .. && npm run electron:compile && electron-builder"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "npm run lint:custom:fix",
      "prettier --write"
    ]
  },
  "build": {
    "appId": "com.diagrambuilder.app",
    "productName": "DiagramBuilder",
    "copyright": "Copyright © 2025 DiagramBuilder",
    "asar": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      ".electron/**/*",
      ".next/**/*",
      "public/**/*",
      "next.config.js",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist",
        "to": "backend/dist"
      },
      {
        "from": "backend/node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*",
          "!puppeteer/.local-chromium/**/*"
        ]
      },
      {
        "from": "backend/package.json",
        "to": "backend/package.json"
      }
    ],
    "dmg": {
      "backgroundColor": "#f0f0f0",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 150,
          "y": 220,
          "type": "file"
        },
        {
          "x": 390,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/dompurify": "^3.0.5",
    "@uiw/react-codemirror": "^4.25.9",
    "dompurify": "^3.4.2",
    "mermaid": "^10.9.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "concurrently": "^9.2.1",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-security": "^2.1.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
